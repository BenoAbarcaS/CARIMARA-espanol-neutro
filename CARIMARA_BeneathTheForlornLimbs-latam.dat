        {
            "key": "letter_0",
            "value": "Lavanda, Violeta"
        },
        {
            "key": "letter_1",
            "value": "Nunca el tiempo ha podido erosionar,"
        },
        {
            "key": "letter_2",
            "value": "ni sus armas, ni su amor."
        },
        {
            "key": "letter_3",
            "value": "Que, a pesar de este merecido descanso, nunca se olviden..."
        },
        {
            "key": "letter_4",
            "value": "El sentido de su presencia aquí."
        },
        {
            "key": "letter_5",
            "value": "Esta catedral está enterrada por una razón."
        },
        {
            "key": "letter_6",
            "value": "La enviada de Leunia jamás debe volver a ver la luz."
        },
        {
            "key": "letter_7",
            "value": "Recuérdenlo siempre."
        },
        {
            "key": "locacreds",
            "value": "LOCALIZACIÓN"
        },
        {
            "key": "violetsecretpath_0",
            "value": "Déjelo..."
        },
        {
            "key": "violetsecretpath_1",
            "value": "Tu papel no está aquí."
        },
        {
            "key": "violetsecretpath_2",
            "value": "Solo fue una pesadilla."
        },
        {
            "key": "violetsecretpath_3",
            "value": "Duérmete, todo está bien..."
        },
        {
            "key": "sleep",
            "value": "DORMIR"
        },
        {
            "key": "thedeer_0",
            "value": "¿Dónde se fueron?"
        },
        {
            "key": "thedeer_1",
            "value": "Digame, te escucho."
        },
        {
            "key": "thedeer_2",
            "value": "..."
        },
        {
            "key": "thedeer_notused_3",
            "value": "Mis preciadas flores..."
        },
        {
            "key": "thedeer_4",
            "value": "Puedo sentir su angustia."
        },
        {
            "key": "thedeer_5",
            "value": "Una se marchita,"
        },
        {
            "key": "thedeer_6",
            "value": "otra ya ha muerto,"
        },
        {
            "key": "thedeer_7",
            "value": "y la última se deja envenenar."
        },
        {
            "key": "thedeer_8",
            "value": "Hace años que la primavera se queda dormida..."
        },
        {
            "key": "thedeer_9",
            "value": "Las raíces se esconden, esperando que vuelvan los días soleados..."
        },
        {
            "key": "thedeer_10",
            "value": "Pero la savia se ha secado hace mucho."
        },
        {
            "key": "thedeer_11",
            "value": "Se acabó, ya no hay nada que hacer."
        },
        {
            "key": "thedeer_12",
            "value": "Entonces, ¿por qué sigue pareciendo tan esperanzado?"
        },
        {
            "key": "thedeer_13",
            "value": "..."
        },
        {
            "key": "thedeer_14",
            "value": "Entiendo."
        },
        {
            "key": "thedeer_15",
            "value": "Es de los que saben burlarse de las reglas de la vida."
        },
        {
            "key": "thedeer_16",
            "value": "De los que no aceptan que las cosas sean como son."
        },
        {
            "key": "thedeer_17",
            "value": "Si es así, adiós...."
        },
        {
            "key": "thedeer_18",
            "value": "..."
        },
        {
            "key": "thedeer_19",
            "value": "El ramo parece un bodegón."
        },
        {
            "key": "toadbringreturn_0",
            "value": "DEVUELVANOSLA..."
        },
        {
            "key": "toadbringreturn_1",
            "value": "TIENE QUE VOLVER..."
        },
        {
            "key": "toadhelpneeded_0",
            "value": "AYUDENOS POR FAVOR..."
        },
        {
            "key": "toadamongus_0",
            "value": "NO DEBE QUEDARSE AQUÍ SOLA..."
        },
        {
            "key": "toadamongus_1",
            "value": "SU LUGAR ESTÁ ENTRE NOSOTROS..."
        },
        {
            "key": "toadmissher_0",
            "value": "LA ECHAMOS TANTO DE MENOS..."
        },
        {
            "key": "toadhelpneeded_1",
            "value": "TE NECESITAMOS..."
        },
        {
            "key": "toadlookather_0",
            "value": "QUEREMOS VERLA DE NUEVO..."
        },
        {
            "key": "toadlookather_1",
            "value": "SÍ, VERLA..."
        },
        {
            "key": "toadlookather_2",
            "value": "UNA ÚLTIMA VEZ."
        },
        {
            "key": "violet_chocked_0",
            "value": "¡Espera!"
        },
        {
            "key": "violet_chocked_1",
            "value": "Tonto..."
        },
        {
            "key": "violet_chocked_2",
            "value": "¿Qué hiciste?"
        },
        {
            "key": "violet_chocked_3",
            "value": "¿Tiene idea de lo grave que es lo que ha hecho?"
        },
        {
            "key": "violet_standingthere_0",
            "value": "Debería haberlo sospechado..."
        },
        {
            "key": "violet_standingthere_1",
            "value": "Este día tenía que llegar tarde o temprano..."
        },
        {
            "key": "violet_standingthere_2",
            "value": "..."
        },
        {
            "key": "violet_cathedralcloseup_0",
            "value": "Lavanda,"
        },
        {
            "key": "violet_cathedralcloseup_1",
            "value": "Al final nos reuniremos antes de lo esperado..."
        },
        {
            "key": "violet_cathedralcloseup_2",
            "value": "Ojalá aún estuvieras aquí."
        },
        {
            "key": "violet_cathedralcloseup_3",
            "value": "Quizás las dos juntas,"
        },
        {
            "key": "violet_cathedralcloseup_4",
